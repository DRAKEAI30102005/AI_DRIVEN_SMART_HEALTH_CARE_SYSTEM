{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["patient", "doctor", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Doctor": {
      "title": "Doctor",
      "description": "Doctor specific information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "specialization": { "type": "string" },
        "clinicName": { "type": "string" },
        "bio": { "type": "string" },
        "availability": { "type": "object" },
        "rating": { "type": "number" }
      },
      "required": ["uid", "specialization"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "Appointment booking details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "patientId": { "type": "string" },
        "doctorId": { "type": "string" },
        "doctorName": { "type": "string" },
        "patientName": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled", "completed"] },
        "notes": { "type": "string" },
        "type": { "type": "string", "enum": ["general", "dental", "consultation"] }
      },
      "required": ["patientId", "doctorId", "date", "status"]
    },
    "HealthRecord": {
      "title": "HealthRecord",
      "description": "Patient medical records",
      "type": "object",
      "properties": {
        "patientId": { "type": "string" },
        "records": { "type": "array", "items": { "type": "object" } },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["patientId"]
    },
    "AIScan": {
      "title": "AIScan",
      "description": "AI Diagnosis scan results",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "patientId": { "type": "string" },
        "imageUrl": { "type": "string" },
        "type": { "type": "string", "enum": ["skin", "dental"] },
        "result": { "type": "string" },
        "confidence": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["patientId", "imageUrl", "type", "result"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/doctors/{doctorId}": {
      "schema": "Doctor",
      "description": "Doctor details"
    },
    "/appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "Appointment bookings"
    },
    "/health_records/{patientId}": {
      "schema": "HealthRecord",
      "description": "Patient health history"
    },
    "/ai_scans/{scanId}": {
      "schema": "AIScan",
      "description": "AI diagnosis results"
    }
  }
}
