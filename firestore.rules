rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, email, displayName, photoURL, role (patient|doctor|admin), createdAt
    //
    // Collection: doctors
    // Fields: uid, specialization, clinicName, bio, availability, rating
    //
    // Collection: appointments
    // Fields: id, patientId, doctorId, doctorName, patientName, date, status, notes, type
    //
    // Collection: health_records
    // Fields: patientId, records, lastUpdated
    //
    // Collection: ai_scans
    // Fields: id, patientId, imageUrl, type, result, confidence, createdAt
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "aritra30102005@gmail.com" && request.auth.token.email_verified == true));
    }

    function isDoctor() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'doctor';
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['patient', 'doctor', 'admin'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == resource.data.role;
      allow delete: if isAdmin();
    }

    match /doctors/{doctorId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isOwner(doctorId);
    }

    match /appointments/{appointmentId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.patientId || request.auth.uid == resource.data.doctorId || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.patientId == request.auth.uid;
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.patientId || request.auth.uid == resource.data.doctorId || isAdmin());
      allow delete: if isAdmin();
    }

    match /health_records/{patientId} {
      allow read: if isOwner(patientId) || isDoctor() || isAdmin();
      allow write: if isOwner(patientId) || isDoctor() || isAdmin();
    }

    match /ai_scans/{scanId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.patientId || isDoctor() || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.patientId == request.auth.uid;
      allow update, delete: if isAdmin();
    }
  }
}
